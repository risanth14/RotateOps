# Copy values into apps/api/.env and apps/web/.env.local

# API (Supabase)
# DATABASE_URL: pooled URL (good for app runtime)
# DIRECT_URL: direct URL (required by Prisma migrate)
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&schema=public"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?schema=public&sslmode=require"
PORT=4000
APP_MODE=demo
API_BASE_URL="http://localhost:4000"
WEB_BASE_URL="http://localhost:3000"

# Auth0
AUTH0_DOMAIN="your-tenant.auth0.com"
AUTH0_AUDIENCE="https://api.rotateops.local"
AUTH0_CLIENT_ID="your_auth0_client_id"
AUTH0_CLIENT_SECRET="your_auth0_client_secret"
AUTH0_ORG_CLAIM="org_id"
AUTH_BYPASS_DEMO=false
STEP_UP_MAX_AGE_SECONDS=900

# DO NOT put real secrets here
SLACK_WEBHOOK_URL="your_slack_webhook_url_here"

ENABLE_AI_SUMMARIES=false
OPENAI_API_KEY="your_openai_api_key_here"

# Token Vault (required when APP_MODE=provider)
TOKEN_VAULT_BASE_URL="http://localhost:4100"
TOKEN_VAULT_API_KEY="your_token_vault_api_key"

# Web
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000"
