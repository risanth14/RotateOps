generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Provider {
  github
  vercel
  stripe
}

enum IntegrationMode {
  demo
  provider
}

enum IntegrationStatus {
  active
  paused
  error
}

enum JobStatus {
  pending
  running
  success
  failed
  manual_intervention
}

enum MembershipRole {
  owner
  admin
  member
}

model Organization {
  id            String                   @id @default(cuid())
  auth0OrgId    String                   @unique
  name          String?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  memberships   OrganizationMembership[]
  integrations  Integration[]
}

model User {
  id            String                   @id @default(cuid())
  auth0UserId   String                   @unique
  email         String?
  name          String?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  memberships   OrganizationMembership[]
  integrations  Integration[]
}

model OrganizationMembership {
  id              String         @id @default(cuid())
  organizationId  String
  userId          String
  role            MembershipRole @default(member)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId, createdAt])
}

model Integration {
  id                 String            @id @default(cuid())
  organizationId     String
  createdByUserId    String?
  provider           Provider
  name               String
  mode               IntegrationMode   @default(demo)
  status             IntegrationStatus @default(active)
  metadata           Json?
  secretFingerprint  String?
  maskedReference    String?
  lastRotatedAt      DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  organization       Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdByUser      User?             @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  policy             RotationPolicy?
  jobs               RotationJob[]
  auditEvents        AuditEvent[]
  secretTargets      SecretTarget[]
  consentGrants      ConsentGrant[]
}

model RotationPolicy {
  id             String      @id @default(cuid())
  integrationId  String      @unique
  intervalDays   Int
  enabled        Boolean     @default(true)
  nextRunAt      DateTime
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  integration    Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  jobs           RotationJob[]
}

model RotationJob {
  id                String      @id @default(cuid())
  integrationId     String
  policyId          String?
  triggeredBy       String
  actor             String?
  consentGrantId    String?
  status            JobStatus   @default(pending)
  startedAt         DateTime?
  completedAt       DateTime?
  failureReason     String?
  aiSummary         String?
  oldFingerprint    String?
  newFingerprint    String?
  rollbackPerformed Boolean     @default(false)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  integration       Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  policy            RotationPolicy? @relation(fields: [policyId], references: [id], onDelete: SetNull)
  consentGrant      ConsentGrant? @relation(fields: [consentGrantId], references: [id], onDelete: SetNull)
  auditEvents       AuditEvent[]

  @@index([integrationId, createdAt])
  @@index([status, createdAt])
}

model AuditEvent {
  id             String        @id @default(cuid())
  jobId          String?
  integrationId  String
  eventType      String
  message        String
  actor          String?
  consentGrantId String?
  metadata       Json?
  createdAt      DateTime      @default(now())
  job            RotationJob?  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  integration    Integration   @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  consentGrant   ConsentGrant? @relation(fields: [consentGrantId], references: [id], onDelete: SetNull)

  @@index([integrationId, createdAt])
  @@index([jobId, createdAt])
}

model SecretTarget {
  id            String      @id @default(cuid())
  integrationId String
  name          String
  kind          String
  config        Json
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
}

model ConsentGrant {
  id            String      @id @default(cuid())
  integrationId String
  provider      Provider
  scopes        String[]
  grantedBy     String
  expiresAt     DateTime?
  revokedAt     DateTime?
  callbackState String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  auditEvents   AuditEvent[]
  jobs          RotationJob[]

  @@index([integrationId])
}
